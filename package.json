{
  "name": "mpc_projects",
  "private": true,
  "type": "module",
  "version": "0.9.0",
  "scripts": {
    "dev": "node --run build:schemas && tsx --watch-path=src/server src/server/main.ts",
    "build:schemas": "tsx bin/build_json_schema.ts config bin/build_json_schemas.json",
    "build:client": "vite build",
    "build:server": "vite build -c vite.config.server.ts",
    "build": "node --run build:schemas && node --run build:client && node --run build:server",
    "build:update-projects": "UPDATE_PROJECTS=true node --run build",
    "start": "node dist/server/main.js",
    "lint": "eslint . --ext ts.tsx --report-unused-disable-directives"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@tanstack/react-query": "^5.91.0",
    "@vitejs/plugin-react": "^6.0.1",
    "body-parser": "^2.2.2",
    "bootstrap": "^5.3.8",
    "cheerio": "^1.2.0",
    "env-var": "^7.5.0",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "iso-639-1": "^3.1.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "undici": "^7.24.4",
    "uuid": "^13.0.0",
    "vite-express": "0.22.1",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.8",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "ajv": "^8.18.0",
    "commander": "^14.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "mpc_api": "https://github.com/North101/mpc_api.git",
    "sass": "^1.98.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-json-schema": "github:impact-merlinzerbe/typescript-json-schema#870259a7c63b15ebfd43cb13b5aa9af3daa1369d",
    "vite": "^8.0.0"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
